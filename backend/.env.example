# --- Database (Neon Postgres) — Implementation Plan Section 1.1 ---
# Pooled connection ("-pooler" in hostname) — used by the running app (asyncpg).
DATABASE_URL=postgresql+asyncpg://user:password@ep-example-pooler.region.aws.neon.tech/exotica?ssl=require
# Direct (non-pooled) connection — used by Alembic migrations only.
DATABASE_URL_DIRECT=postgresql+asyncpg://user:password@ep-example.region.aws.neon.tech/exotica?ssl=require

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- CORS - comma-separated list of allowed frontend origins ---
CORS_ALLOWED_ORIGINS_RAW=http://localhost:3000,http://localhost:5173

# --- Business defaults (bootstrap only — live value lives in SystemSetting once seeded) ---
DEAD_STOCK_WINDOW_DAYS=45
